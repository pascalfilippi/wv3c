{
    "app-id": "de.pascalfilippi.WolverineLinux",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "25.08",
    "sdk": "org.freedesktop.Sdk",
    "command": "wolverine-gui",
    "finish-args": [
        "--socket=wayland",
        "--socket=fallback-x11",
        "--share=ipc",
        "--device=all"
    ],
    "modules": [
        "python3-deps.json",
        {
            "name": "wolverine-linux",
            "buildsystem": "simple",
            "build-commands": [
                "pip3 install --no-build-isolation --no-deps --prefix=/app .",
                "install -Dm644 data/de.pascalfilippi.WolverineLinux.desktop /app/share/applications/de.pascalfilippi.WolverineLinux.desktop"
            ],
            "sources": [
                {
                    "type": "dir",
                    "path": "."
                }
            ]
        }
    ]
}
